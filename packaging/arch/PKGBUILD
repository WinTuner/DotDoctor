# Maintainer: Arch Developer <developer@dotdoctor.com>
pkgname=dotdoctor
pkgver=1.0.0
pkgrel=1
pkgdesc="🩺 Real-time interactive TUI dashboard for scanning & auto-fixing Hyprland dependencies, binaries, and fonts"
arch=('x86_64' 'aarch64')
url="https://github.com/WinTuner/DotDoctor"
license=('MIT')
depends=('glibc')
makedepends=('go')
optdepends=('fontconfig: for system font verification'
            'yay: AUR helper for TUI auto-fixing capability'
            'paru: AUR helper for TUI auto-fixing capability')
source=("$pkgname-$pkgver.tar.gz::https://github.com/WinTuner/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  mkdir -p build
}

build() {
  cd "$pkgname-$pkgver"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"
  
  go build -ldflags="-s -w -X main.Version=$pkgver" -o build/dotdoctor ./cmd/dotdoctor
}

check() {
  cd "$pkgname-$pkgver"
  go test ./...
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 build/dotdoctor "$pkgdir/usr/bin/dotdoctor"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
